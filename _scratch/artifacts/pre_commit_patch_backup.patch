-    def _find_answer(self, question: str) -> str:
-        """Match question to knowledge base or use AI."""
-        question_lower = question.lower()
-
-        # Try pattern matching first (fast, deterministic)
-        for pattern, response in self.knowledge_base.items():
-            if re.search(pattern, question_lower):
-                return response["answer"]
-
-        # If pattern matching fails, use TinyLM AI (lazy init)
-        if self.use_ai:
-            # Initialize TinyLM only when first needed
-            if self.tinylm is None:
-                self.tinylm = SparkTinyLM()
-
-            answer, success = self.tinylm.generate_answer(question)
-            if success:
-                return answer
-
-        # Default response (fallback)
-        return (
-            "I'm not sure about that specific question. Here are some things I can help with:\n\n"
-            "• Starting/stopping acquisitions\n"
-            "• Exporting and saving data\n"
-            "• Detector connection issues\n"
-            "• Pump controls and flow\n"
-            "• Creating and editing cycles\n"
-            "• Baseline corrections\n\n"
-            "Try rephrasing your question, or check the Help menu for documentation."
