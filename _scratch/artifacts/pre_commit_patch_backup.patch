-
-        if not question:
-            return
-
-        # Clear input
-        self.question_input.clear()
-
-        # Add user question bubble
-        user_bubble = MessageBubble(question, is_user=True)
-        self.chat_layout.addWidget(user_bubble, alignment=Qt.AlignmentFlag.AlignLeft)
