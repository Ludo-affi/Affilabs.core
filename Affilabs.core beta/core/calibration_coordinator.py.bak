"""Calibration Coordinator - Manages calibration workflow and UI interactions.

This coordinator handles:
- Calibration dialog lifecycle
- Calibration progress tracking
- Retry/Continue logic
- Success/failure handling
- S/P validation and device config updates

Extracted from main_simplified.py to improve modularity and testability.
"""

import numpy as np
from PySide6.QtCore import QObject, QTimer, Qt
from PySide6.QtWidgets import QPushButton, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout
import pyqtgraph as pg
from utils.logger import logger
from typing import Optional, Dict, Any


class CalibrationCoordinator(QObject):
    """Manages calibration workflow and dialog interactions."""

    def __init__(self, app):
        """Initialize calibration coordinator.

        Args:
            app: Reference to main Application instance
        """
        super().__init__()
        self.app = app

        # Dialog and state tracking
        self._calibration_dialog: Optional[Any] = None
        self._calibration_retry_count: int = 0
        self._max_calibration_retries: int = 3
        self._calibration_completed: bool = False

        # Progress tracking
        self._calibration_steps_total: int = 7
        self._calibration_steps_completed: int = 0

        # Simple live window
        self._simple_live_window: Optional[Any] = None

    def start_calibration(self) -> None:
        """Start calibration routine and show progress dialog."""
        logger.info("🎬 CalibrationCoordinator.start_calibration() called")

        # Reset calibration state for new calibration
        self._calibration_completed = False
        self._calibration_retry_count = 0

        from affilabs_core_ui import StartupCalibProgressDialog

        # Build calibration message - clear checklist for user action
        message = (
            "Please verify before calibrating:\n\n"
            "  ✓  Prism installed in sensor holder\n"
            "  ✓  Water or buffer applied to prism\n"
            "  ✓  No air bubbles visible\n"
            "  ✓  Temperature stabilized (10 min after power-on)\n\n"
            "Calibration takes approximately 30-60 seconds."
        )

        logger.debug("📋 Creating calibration dialog...")
        self._calibration_dialog = StartupCalibProgressDialog(
            parent=self.app.main_window,
            title="Calibrating SPR System",
            message=message,
            show_start_button=True  # User confirms checklist before starting
        )
        logger.debug(f"   Dialog created: {self._calibration_dialog is not None}")

        # Connect dialog signals
        self._calibration_dialog.start_clicked.connect(self._on_calibration_start_button_clicked)
        self._calibration_dialog.retry_clicked.connect(self._on_retry_clicked)
        self._calibration_dialog.continue_anyway_clicked.connect(self._on_continue_anyway_clicked)
        logger.debug("   Signals connected")

        # Initialize progress - hide bar until calibration starts
        self._calibration_steps_completed = 0
        self._calibration_dialog.hide_progress_bar()  # No progress bar during checklist
        logger.debug("   Progress bar hidden, showing dialog...")
        self._calibration_dialog.show()

        # Enable Start button so user can confirm checklist and begin
        # Use pre_calib version to NOT set _is_complete flag
        self._calibration_dialog.enable_start_button_pre_calib()
        logger.info("✅ Calibration dialog displayed with Start button enabled")

    def on_calibration_started(self) -> None:
        """Handle calibration start event.

        Called when calibration process begins. Can be used to reset state,
        show progress dialog, or perform other initialization.
        """
        logger.info("🔧 Calibration started")
        # Dialog is already shown in start_led_calibration, but we can update status here
        if hasattr(self, '_calibration_dialog') and self._calibration_dialog:
            self._calibration_dialog.update_status("Calibration in progress...")

    def on_calibration_complete(self, calibration_data: Dict[str, Any]) -> None:
        """Handle calibration completion.

        Args:
            calibration_data: Dict containing calibration results
        """
        logger.info("🎯 CalibrationCoordinator.on_calibration_complete() called")
        logger.debug(f"   Calibration data keys: {list(calibration_data.keys())}")

        ch_error_list = calibration_data.get('ch_error_list', [])
        calibration_type = calibration_data.get('calibration_type', 'full')
        s_ref_qc_results = calibration_data.get('s_ref_qc_results', {})
        afterglow_available = calibration_data.get('afterglow_available', False)
        sp_validation = calibration_data.get('sp_validation_results', {})

        logger.debug(f"   Error list: {ch_error_list}, Type: {calibration_type}")

        # Log results
        self._log_calibration_summary(calibration_data, calibration_type, sp_validation, afterglow_available)

        # Save S/P validation
        self._save_sp_validation(sp_validation)

        # Note: Legacy OEM calibration popup removed - modern workflow handles this automatically
        # via _run_led_then_afterglow_calibration() in main_simplified.py when optical cal missing

        # Update hardware manager
        self.app.hardware_mgr.update_calibration_status(ch_error_list, calibration_type, s_ref_qc_results)

        # Update FWHM measurements to set sensor_ready status
        if sp_validation and isinstance(sp_validation, dict):
            for ch_key, ch_data in sp_validation.items():
                if isinstance(ch_data, dict) and 'fwhm' in ch_data:
                    fwhm = ch_data['fwhm']
                    if fwhm is not None:
                        self.app.hardware_mgr.update_fwhm(ch_key, fwhm)
                        logger.debug(f"📊 Updated FWHM for channel {ch_key}: {fwhm:.1f} nm")

        # Handle errors or success
        if len(ch_error_list) > 0:
            self._handle_calibration_errors(ch_error_list)
        else:
            self._handle_calibration_success()

        # Save calibration to device config
        if len(ch_error_list) == 0:
            self._save_calibration_to_device_config(calibration_data)
            self._update_led_intensities_in_ui()

    def on_calibration_failed(self, error: str) -> None:
        """Handle calibration failure.

        Args:
            error: Error message
        """
        logger.error(f"Calibration failed: {error}")

        # Check for critical error details
        critical_error_info = None
        if hasattr(self.app.hardware_mgr, 'calibrator') and self.app.hardware_mgr.calibrator:
            critical_error_info = self.app.hardware_mgr.calibrator.get_last_critical_error()

        # Update dialog
        if self._calibration_dialog:
            self._calibration_dialog.update_title("❌ Calibration Failed")
            self._calibration_dialog.update_status(f"Error: {error}\n\nDialog will close automatically.")
            QTimer.singleShot(4000, self._close_dialog)

        # Show detailed error if available
        if critical_error_info:
            self._show_critical_error_dialog(critical_error_info)
        else:
            from widgets.message import show_message
            show_message(error, "Calibration Error")

    def on_calibration_progress(self, message: str) -> None:
        """Update calibration progress.

        Args:
            message: Progress message
        """
        logger.info(f"📊 Calibration progress: {message}")

        if self._calibration_dialog and not self._calibration_dialog._is_closing:
            try:
                # Map progress messages to percentage completion
                progress_map = {
                    "initializing": 10,
                    "calibrating system": 20,
                    "calibrating led a": 30,
                    "calibrating led b": 45,
                    "calibrating led c": 60,
                    "calibrating led d": 75,
                    "measuring dark": 80,
                    "measuring reference": 85,
                    "finalizing": 90,
                    "completing calibration": 95,
                    "complete": 100
                }

                # Determine progress percentage based on message content
                progress_percent = 20  # Default
                message_lower = message.lower()
                for keyword, percent in progress_map.items():
                    if keyword in message_lower:
                        progress_percent = percent
                        break

                # Use QTimer to marshal UI updates to the main thread (thread-safe)
                from PySide6.QtCore import QTimer
                QTimer.singleShot(0, lambda: self._update_progress_ui(message, progress_percent))
                logger.debug(f"   Progress bar update queued: {progress_percent}%")
            except (RuntimeError, AttributeError) as e:
                logger.warning(f"Failed to update progress dialog: {e}")

    def _update_progress_ui(self, message: str, progress_percent: int) -> None:
        """Update progress UI in main thread (called via QTimer).

        Args:
            message: Progress message
            progress_percent: Progress percentage (0-100)
        """
        if self._calibration_dialog and not self._calibration_dialog._is_closing:
            try:
                self._calibration_dialog.update_status(message)
                self._calibration_dialog.set_progress(progress_percent, 100)
            except (RuntimeError, AttributeError):
                pass  # Dialog may have closed

    def _on_calibration_start_button_clicked(self) -> None:
        """Handle Start button click on calibration dialog - begins LED calibration."""

        # Check if calibration is already complete (use coordinator flag OR dialog flag)
        if self._calibration_completed or (self._calibration_dialog and self._calibration_dialog._is_complete):
            logger.info("✅ Calibration complete - starting data acquisition")
            # Dialog will close itself via _on_start_clicked()
            # Just start acquisition
            self._start_acquisition_after_calibration()
            return

        logger.info("🎬 Calibration Start button clicked - beginning LED calibration")

        # Validate system state
        if hasattr(self.app.data_mgr, '_calibrating') and self.app.data_mgr._calibrating:
            logger.warning("⚠️ Calibration already in progress")
            return

        # Update dialog to show calibration is running
        if self._calibration_dialog:
            # Disable Start button during calibration
            if self._calibration_dialog.start_button:
                self._calibration_dialog.start_button.setEnabled(False)

            self._calibration_dialog.show_progress_bar()  # Show progress bar now
            self._calibration_dialog.update_status("Running LED intensity calibration...")
            self._calibration_dialog.set_progress(10, 100)

        # Start LED calibration
        self.app.data_mgr.start_calibration()
        logger.info("✅ LED calibration started")

    def _start_acquisition_after_calibration(self) -> None:
        """Start data acquisition after successful calibration."""
        try:
            logger.info("🎬 Starting data acquisition after calibration")

            # Validate system state
            if not self.app.data_mgr.calibrated:
                logger.error("❌ Cannot start acquisition - system not calibrated")
                return

            # Check if acquisition already running
            if self.app.data_mgr._acquiring:
                logger.warning("⚠️ Acquisition already running - skipping auto-start")
                return

            # Warn if optics not ready
            if hasattr(self.app.hardware_mgr, '_optics_verified') and not self.app.hardware_mgr._optics_verified:
                logger.warning("⚠️ Starting acquisition with optics NOT ready")
                self.app.main_window._set_optics_warning()

            # Start acquisition
            try:
                logger.info("📞 Calling data_mgr.start_acquisition()...")
                self.app.data_mgr.start_acquisition()
                logger.info("✅ Data acquisition started successfully")

                # Close the calibration dialog after successful start
                if self._calibration_dialog and not self._calibration_dialog._is_closing:
                    logger.info("📋 Closing calibration dialog now that acquisition started")
                    from PySide6.QtCore import QTimer
                    def close_dialog():
                        if self._calibration_dialog:
                            self._calibration_dialog._is_closing = True
                            self._calibration_dialog.close()
                            self._calibration_dialog = None
                            logger.info("📋 Calibration dialog closed")
                    QTimer.singleShot(100, close_dialog)

                # Start countdown timer if cycle queued
                if hasattr(self.app.main_window, 'cycle_queue') and self.app.main_window.cycle_queue:
                    running_cycle = next((c for c in self.app.main_window.cycle_queue if c.get('state') == 'running'), None)
                    if running_cycle and 'length_minutes' in running_cycle:
                        self.app.main_window.start_cycle_countdown(running_cycle['length_minutes'])
            except Exception as e:
                logger.error(f"❌ Failed to start data acquisition: {e}", exc_info=True)
                from widgets.message import show_message
                show_message(f"Failed to start acquisition:\n{e}", "Acquisition Error")
        except Exception as e:
            logger.error(f"❌ CRASH in _start_acquisition_after_calibration: {e}", exc_info=True)
            import traceback
            traceback.print_exc()

    def _on_start_button_clicked(self) -> None:
        """Handle Start button click for data acquisition (different from calibration start)."""
        logger.info("🎬 Start button clicked - initiating data acquisition")

        # Validate system state
        if hasattr(self.app.data_mgr, '_calibrating') and self.app.data_mgr._calibrating:
            logger.warning("⚠️ Calibration still in progress")
            from widgets.message import show_message
            show_message(
                "Calibration is still in progress.\n\nPlease wait for completion.",
                "Calibration In Progress"
            )
            return

        if not self.app.data_mgr.calibrated:
            from widgets.message import show_message
            show_message(
                "Please calibrate the system first.",
                "Calibration Required"
            )
            return

        if self.app.data_mgr._acquiring:
            logger.warning("Data acquisition already running")
            return

        # Clear dialog reference
        if self._calibration_dialog:
            self._calibration_dialog = None

        # Warn if optics not ready
        if hasattr(self.app.hardware_mgr, '_optics_verified') and not self.app.hardware_mgr._optics_verified:
            logger.warning("⚠️ Starting acquisition with optics NOT ready")
            self.app.main_window._set_optics_warning()

        # Start acquisition
        try:
            self.app.data_mgr.start_acquisition()
            logger.info("✅ Data acquisition started successfully")

            # Start countdown timer if cycle queued
            if hasattr(self.app.main_window, 'cycle_queue') and self.app.main_window.cycle_queue:
                running_cycle = next((c for c in self.app.main_window.cycle_queue if c.get('state') == 'running'), None)
                if running_cycle and 'length_minutes' in running_cycle:
                    self.app.main_window.start_cycle_countdown(running_cycle['length_minutes'])
        except Exception as e:
            logger.error(f"Failed to start data acquisition: {e}")
            from widgets.message import show_message
            show_message(f"Failed to start acquisition:\n{e}", "Acquisition Error")

    def _on_retry_clicked(self) -> None:
        """Handle Retry button click."""
        logger.info(f"🔄 User chose to retry calibration (attempt {self._calibration_retry_count + 1}/{self._max_calibration_retries})")

        self._calibration_completed = False

        if self._calibration_dialog and not self._calibration_dialog._is_closing:
            try:
                self._calibration_dialog.reset_to_progress_state()
                self._calibration_dialog.update_title("Retrying Calibration")
                self._calibration_dialog.update_status("Restarting calibration process...")
                self._calibration_dialog.set_progress(0, 100)
                self._calibration_steps_completed = 0
            except Exception as e:
                logger.error(f"Failed to reset dialog: {e}")

        self.app.data_mgr.start_calibration()

    def _on_continue_anyway_clicked(self) -> None:
        """Handle Continue Anyway button click."""
        logger.info("✅ User chose to continue despite calibration failures")

        self._calibration_retry_count = 0
        self._calibration_completed = True

        # Update dialog to partial success state
        if self._calibration_dialog and not self._calibration_dialog._is_closing:
            try:
                self._calibration_dialog.reset_to_progress_state()
                self._calibration_dialog.update_title("⚠️ Ready (Partial Calibration)")
                self._calibration_dialog.update_status(
                    "Some channels failed calibration.\n\n"
                    "You can proceed with available channels.\n"
                    "Press Start to begin data acquisition."
                )
                self._calibration_dialog.set_progress(100, 100)

                # Ensure Start button exists
                if not self._calibration_dialog.start_button:
                    self._create_start_button()

                self._calibration_dialog.start_button.show()
                self._calibration_dialog.enable_start_button()

                if hasattr(self._calibration_dialog, 'overlay') and self._calibration_dialog.overlay:
                    self._calibration_dialog.overlay.hide()
            except Exception as e:
                logger.error(f"Failed to update dialog: {e}")

        # Save partial calibration
        self._save_partial_calibration()
        self._update_led_intensities_in_ui()

    def _handle_calibration_errors(self, ch_error_list: list) -> None:
        """Handle calibration errors with retry logic."""
        logger.warning(f"⚠️ Calibration completed with errors in channels: {ch_error_list}")

        self._calibration_retry_count += 1

        # Check for maintenance requirements
        maintenance_required = []
        for ch in ch_error_list:
            if ch in self.app.hardware_mgr._maintenance_required:
                maintenance_required.append(ch)

        # Build error message
        ch_str = ", ".join([ch.upper() for ch in ch_error_list])

        if self._calibration_retry_count >= self._max_calibration_retries:
            # Max retries reached
            error_msg = self._build_error_message(ch_str, maintenance_required)
            if self._calibration_dialog and not self._calibration_dialog._is_closing:
                try:
                    self._calibration_dialog.show_max_retries_error(error_msg)
                    logger.info("📋 Max retries reached - showing Continue option")
                except Exception as e:
                    logger.error(f"Failed to update dialog: {e}")
        else:
            # Show retry/continue options
            error_msg = self._build_error_message(ch_str, maintenance_required)
            if self._calibration_dialog and not self._calibration_dialog._is_closing:
                try:
                    self._calibration_dialog.show_error_state(
                        error_msg,
                        self._calibration_retry_count,
                        self._max_calibration_retries
                    )
                    logger.info("📋 Calibration failed - showing Retry/Continue options")
                except Exception as e:
                    logger.error(f"Failed to update dialog: {e}")

    def _handle_calibration_success(self) -> None:
        """Handle successful calibration."""
        logger.info("✅ All channels calibrated successfully - optics ready")
        self._calibration_retry_count = 0
        self._calibration_completed = True

        # Show QC report dialog FIRST (blocking) before continuing
        self._show_qc_report()

        # Debug: Check dialog state
        logger.debug(f"📋 Dialog state: exists={self._calibration_dialog is not None}, closing={self._calibration_dialog._is_closing if self._calibration_dialog else 'N/A'}")

        # Auto-start acquisition if enabled (check BEFORE dialog update to ensure it runs)
        import os
        auto_flag = os.environ.get('AFFILABS_AUTO_START_AFTER_CAL', '0')  # Changed default to '0' (disabled) to prevent crash
        should_auto_start = auto_flag not in ('0', 'false', 'False') and not self.app.data_mgr._acquiring

        if should_auto_start:
            logger.info("🚀 Auto-start enabled - will start acquisition after dialog update")

        if self._calibration_dialog and not self._calibration_dialog._is_closing:
            def update_dialog_success():
                if self._calibration_dialog and not self._calibration_dialog._is_closing:
                    try:
                        logger.info("📋 Updating calibration dialog to completion state...")
                        self._calibration_dialog.update_title("✅ Calibration Complete")

                        # Update status based on auto-start setting
                        if should_auto_start:
                            self._calibration_dialog.update_status("All channels are ready!\n\nStarting live data acquisition...")
                        else:
                            self._calibration_dialog.update_status("All channels are ready!\n\nPress Start to begin data acquisition.")

                        self._calibration_dialog.set_progress(100, 100)
                        self._calibration_dialog.enable_start_button()

                        if hasattr(self._calibration_dialog, 'overlay') and self._calibration_dialog.overlay:
                            self._calibration_dialog.overlay.hide()

                        logger.info("📋 Calibration complete - Start button enabled")

                        # Trigger auto-start if enabled
                        if should_auto_start:
                            logger.info("🚀 Auto-starting acquisition (AFFILABS_AUTO_START_AFTER_CAL enabled)")
                            # Defer start to allow dialog update to complete
                            QTimer.singleShot(300, self._start_acquisition_after_calibration)
                        else:
                            if self.app.data_mgr._acquiring:
                                logger.debug("Acquisition already running; auto-start skipped")
                            else:
                                logger.info("⏯ Manual start required (set AFFILABS_AUTO_START_AFTER_CAL=1 to enable auto)")
                    except (RuntimeError, AttributeError) as e:
                        logger.warning(f"Dialog state error: {e}")

                        # Fallback: still auto-start even if dialog fails
                        if should_auto_start:
                            logger.info("🚀 Dialog failed but auto-starting acquisition anyway")
                            QTimer.singleShot(100, self._start_acquisition_after_calibration)
                        else:
                            from widgets.message import show_message
                            show_message(
                                "Calibration completed successfully!\n\nPress the Start button to begin acquisition.",
                                'Information'
                            )

            QTimer.singleShot(0, update_dialog_success)
        else:
            logger.warning(f"⚠️ Cannot update dialog: dialog={'exists' if self._calibration_dialog else 'None'}, closing={self._calibration_dialog._is_closing if self._calibration_dialog else 'N/A'}")

            # No dialog or dialog closed - still auto-start if enabled
            if should_auto_start:
                logger.info("🚀 No dialog present but auto-starting acquisition")
                QTimer.singleShot(100, self._start_acquisition_after_calibration)

    def _log_calibration_summary(self, data: dict, cal_type: str, sp_val: dict, afterglow: bool) -> None:
        """Log calibration summary."""
        logger.info(f"✅ Calibration complete ({cal_type})")
        logger.info(f"📊 Integration time: {data.get('integration_time', 'unknown')}ms, Num scans: {data.get('num_scans', 'unknown')}")

        leds = data.get('leds_calibrated', {})
        if leds:
            led_str = ", ".join([f"Ch {ch.upper()}: {intensity}" for ch, intensity in sorted(leds.items())])
            logger.info(f"💡 LED Intensities: {led_str}")

        if sp_val:
            for ch, result in sp_val.items():
                status_icon = "✅" if result.get('orientation_correct') else "⚠️"
                logger.info(f"{status_icon} Ch {ch.upper()} S/P: confidence={result.get('confidence', 0):.2f}, peak={result.get('peak_wl', 0):.1f}nm")

        if afterglow:
            logger.info("✅ Afterglow correction is ACTIVE")
        else:
            logger.info("⚠️ Afterglow correction NOT loaded")

    def _save_sp_validation(self, sp_validation: dict) -> None:
        """Save S/P validation to device config."""
        if self.app.main_window.device_config and sp_validation:
            try:
                self.app.main_window.device_config.save_sp_validation(sp_validation)
                logger.info("💾 S/P orientation validation saved to device config")
            except Exception as e:
                logger.warning(f"Failed to save S/P validation: {e}")

    # Legacy OEM prompt removed - modern workflow automatically runs LED+afterglow calibration
    # when optical cal file is missing (handled in main_simplified.py _on_hardware_connected)

    def _save_calibration_to_device_config(self, calibration_data: dict) -> None:
        """Save calibration data to device config (single source of truth).
        
        ========================================================================
        CRITICAL: DEVICE_CONFIG.JSON IS THE SINGLE SOURCE OF TRUTH
        ========================================================================
        This method saves ALL calibration results to device_config.json:
        
        1. Integration time (ms) - ALWAYS calibrated, never cached
        2. S-mode LED intensities per channel (0-255)
        3. P-mode LED intensities per channel (0-255)
        4. S-mode reference spectra (numpy arrays)
        5. Wavelengths array
        
        These values are used for:
        - Fast-track calibration mode (validates saved LED values on hardware)
        - QC validation (compares new calibration against saved baseline)
        - Live acquisition (uses calibrated integration time and LED values)
        
        device_config.json is the ONLY source for fast-track decision.
        NO other files (optical calibration, etc.) are used for this logic.
        ========================================================================
        """
        if self.app.main_window.device_config:
            try:
                # Extract calibration data
                integration_time = calibration_data.get('integration_time')
                s_mode_intensities = calibration_data.get('leds_calibrated', {})
                p_mode_intensities = calibration_data.get('p_mode_intensities', s_mode_intensities)  # Fallback to S-mode if P-mode not available
                calibration_method = self.app.data_mgr.calibration_method if hasattr(self.app.data_mgr, 'calibration_method') else 'standard'
                per_channel_integration = self.app.data_mgr.per_channel_integration if hasattr(self.app.data_mgr, 'per_channel_integration') else {}
                
                # Get reference spectra from data manager if available
                s_ref_spectra = {}
                if hasattr(self.app.data_mgr, 's_ref_data') and self.app.data_mgr.s_ref_data:
                    for ch, data in self.app.data_mgr.s_ref_data.items():
                        if isinstance(data, np.ndarray):
                            s_ref_spectra[ch] = data
                        elif isinstance(data, dict) and 'spectrum' in data:
                            s_ref_spectra[ch] = data['spectrum']
                
                # Get wavelengths if available
                s_ref_wavelengths = None
                if hasattr(self.app.data_mgr, 'wave_data') and self.app.data_mgr.wave_data is not None:
                    s_ref_wavelengths = self.app.data_mgr.wave_data
                
                # Save using unified API (device_config.json is single source of truth)
                if integration_time and s_mode_intensities and s_ref_spectra:
                    self.app.main_window.device_config.save_led_calibration(
                        integration_time_ms=integration_time,
                        s_mode_intensities=s_mode_intensities,
                        p_mode_intensities=p_mode_intensities,
                        s_ref_spectra=s_ref_spectra,
                        s_ref_wavelengths=s_ref_wavelengths,
                        calibration_method=calibration_method,
                        per_channel_integration_times=per_channel_integration if calibration_method == 'alternative' else None
                    )
                    logger.info("💾 LED calibration saved to device_config.json (single source of truth)")
                    logger.info(f"   Method: {calibration_method}, Integration: {integration_time}ms, S-mode LEDs: {s_mode_intensities}")
                else:
                    # Fallback to legacy save if new format data not available
                    logger.warning("⚠️ Using legacy calibration save (missing reference spectra)")
                    if s_mode_intensities:
                        self.app.main_window.device_config.set_led_intensities(
                            s_mode_intensities.get('a', 0),
                            s_mode_intensities.get('b', 0),
                            s_mode_intensities.get('c', 0),
                            s_mode_intensities.get('d', 0)
                        )
                    num_scans = calibration_data.get('num_scans')
                    if integration_time and num_scans:
                        self.app.main_window.device_config.set_calibration_settings(integration_time, num_scans)
                    self.app.main_window.device_config.save()
                    logger.info("💾 Calibration settings saved to device config file (legacy format)")
                    
            except Exception as e:
                logger.error(f"Failed to save calibration to device config: {e}")
                logger.exception(e)

    def _save_partial_calibration(self) -> None:
        """Save partial calibration data."""
        if self.app.main_window.device_config:
            try:
                if hasattr(self.app.data_mgr, 'leds_calibrated'):
                    self.app.main_window.device_config.set_led_intensities(
                        self.app.data_mgr.leds_calibrated.get('a', 0),
                        self.app.data_mgr.leds_calibrated.get('b', 0),
                        self.app.data_mgr.leds_calibrated.get('c', 0),
                        self.app.data_mgr.leds_calibrated.get('d', 0)
                    )

                if hasattr(self.app.data_mgr, 'integration_time') and hasattr(self.app.data_mgr, 'num_scans'):
                    self.app.main_window.device_config.set_calibration_settings(
                        self.app.data_mgr.integration_time,
                        self.app.data_mgr.num_scans
                    )

                self.app.main_window.device_config.save()
                logger.info("💾 Partial calibration settings saved to device config")
            except Exception as e:
                logger.warning(f"Failed to save partial calibration: {e}")

    def _update_led_intensities_in_ui(self) -> None:
        """Update LED intensity displays in UI."""
        if hasattr(self.app, '_update_led_intensities_in_ui'):
            self.app._update_led_intensities_in_ui()

    def _build_error_message(self, ch_str: str, maintenance_required: list) -> str:
        """Build calibration error message."""
        if len(maintenance_required) > 0:
            maint_str = ", ".join([ch.upper() for ch in maintenance_required])
            return (f"Channels {ch_str} failed.\n"
                   f"Channels {maint_str} show weak LED intensity\n"
                   f"and may require LED PCB replacement.")
        else:
            return (f"Channels {ch_str} failed.\n"
                   f"The optics may require cleaning or adjustment.")

    def _create_start_button(self) -> None:
        """Create Start button for dialog."""
        self._calibration_dialog.start_button = QPushButton("Start")
        self._calibration_dialog.start_button.setFixedSize(140, 36)
        self._calibration_dialog.start_button.setStyleSheet(
            "QPushButton {"
            "  background: #007AFF;"
            "  color: white;"
            "  border: none;"
            "  border-radius: 6px;"
            "  font-size: 13px;"
            "  font-weight: 600;"
            "  padding: 8px 16px;"
            "}"
            "QPushButton:hover { background: #0051D5; }"
            "QPushButton:pressed { background: #004FC4; }"
            "QPushButton:disabled { background: #E5E5EA; color: #86868B; }"
        )
        self._calibration_dialog.start_button.clicked.connect(self._calibration_dialog._on_start_clicked)
        self._calibration_dialog.button_layout.insertWidget(1, self._calibration_dialog.start_button)

    def _show_critical_error_dialog(self, error_info: dict) -> None:
        """Show critical error dialog with detailed information."""
        if hasattr(self.app, '_show_critical_calibration_error_dialog'):
            self.app._show_critical_calibration_error_dialog(error_info)

    def _show_qc_report(self) -> None:
        """Show calibration QC report with 5 graphs."""
        try:
            logger.info("📊 Preparing calibration QC report...")

            # Collect calibration data from hardware manager
            qc_data = self._collect_qc_data()

            if not qc_data:
                logger.warning("⚠️ No QC data available - showing empty QC report anyway for user visibility")
                # Show empty dialog so user knows calibration completed
                qc_data = {
                    's_pol_spectra': {},
                    'p_pol_spectra': {},
                    'dark_scan': {},
                    'afterglow_curves': {},
                    'transmission_spectra': {},
                    'wavelengths': np.linspace(560, 720, 3648),
                    'integration_time': 0,
                    'led_intensities': {}
                }

            logger.info(f"📊 Showing QC dialog with {len(qc_data.get('s_pol_spectra', {}))} channels...")

            # Show QC dialog (blocking)
            from widgets.calibration_qc_dialog import CalibrationQCDialog
            result = CalibrationQCDialog.show_qc_report(
                parent=self.app.main_window,
                calibration_data=qc_data
            )

            logger.info(f"✅ QC report closed (user dismissed dialog, result={result})")

        except Exception as e:
            logger.error(f"❌ Failed to show QC report: {e}", exc_info=True)
            # Don't fail calibration if QC report fails - just log and continue

    def _collect_qc_data(self) -> dict:
        """Collect calibration data for QC report.

        Returns:
            Dictionary containing:
                - s_pol_spectra: dict of {channel: spectrum_array}
                - p_pol_spectra: dict of {channel: spectrum_array}
                - dark_scan: dict of {channel: dark_array}
                - afterglow_curves: dict of {channel: afterglow_array}
                - transmission_spectra: dict of {channel: transmission_array}
                - wavelengths: array of wavelength values
                - integration_time: float (ms)
                - led_intensities: dict of {channel: intensity}
        """
        try:
            # Calibration data is stored directly in data_mgr
            data_mgr = self.app.data_mgr
            
            logger.debug(f"Collecting QC data from data_mgr...")
            logger.debug(f"Has ref_sig: {hasattr(data_mgr, 'ref_sig')}")
            logger.debug(f"Has dark_noise: {hasattr(data_mgr, 'dark_noise')}")
            logger.debug(f"Has leds_calibrated: {hasattr(data_mgr, 'leds_calibrated')}")

            # Get wavelength array from data_mgr (already trimmed during calibration)
            wavelengths = data_mgr.wave_data if hasattr(data_mgr, 'wave_data') else None
            
            if wavelengths is None:
                wavelengths = np.linspace(560, 720, 3648)  # Default detector range
                logger.debug(f"Using default wavelength array: length={len(wavelengths)}")
            else:
                logger.debug(f"Got wavelengths from data_mgr: length={len(wavelengths)}")

            # Collect S-pol spectra (ref_sig contains S-mode reference spectra)
            s_pol_spectra = {}
            if hasattr(data_mgr, 'ref_sig') and data_mgr.ref_sig:
                s_pol_spectra = dict(data_mgr.ref_sig)
                logger.debug(f"Collected S-pol spectra for channels: {list(s_pol_spectra.keys())}")
                for ch, spec in s_pol_spectra.items():
                    if spec is not None:
                        logger.debug(f"  Channel {ch}: {len(spec)} points, range={np.min(spec):.1f}-{np.max(spec):.1f}")
            else:
                logger.warning("ref_sig not available in data_mgr")

            # Collect P-pol spectra (we need to capture these during calibration)
            # For now, use ref_sig as placeholder since P-mode data isn't separately stored
            p_pol_spectra = s_pol_spectra.copy()  # TODO: Store P-mode spectra during calibration

            # Collect dark scan (dark_noise contains the dark spectrum)
            dark_scan = {}
            if hasattr(data_mgr, 'dark_noise') and data_mgr.dark_noise is not None:
                if isinstance(data_mgr.dark_noise, np.ndarray):
                    # Dark is a single array, replicate for all channels
                    for ch in ['a', 'b', 'c', 'd']:
                        if ch in s_pol_spectra:  # Only add if channel was calibrated
                            dark_scan[ch] = data_mgr.dark_noise

            # Collect afterglow curves (no direct storage, generate zeros for now)
            afterglow_curves = {}
            if wavelengths is not None:
                for ch in s_pol_spectra.keys():
                    # Placeholder: zero afterglow (actual correction is applied during acquisition)
                    afterglow_curves[ch] = np.zeros_like(wavelengths)

            # Calculate transmission spectra (S/P ratio)
            transmission_spectra = {}
            for ch in ['a', 'b', 'c', 'd']:
                if ch in s_pol_spectra and ch in p_pol_spectra:
                    s_spectrum = s_pol_spectra[ch]
                    p_spectrum = p_pol_spectra[ch]

                    # Avoid division by zero
                    with np.errstate(divide='ignore', invalid='ignore'):
                        transmission = np.where(
                            s_spectrum > 0,
                            (p_spectrum / s_spectrum) * 100.0,
                            0.0
                        )
                    transmission_spectra[ch] = transmission

            # Get integration time and LED intensities
            integration_time = getattr(data_mgr, 'integration_time', 0)
            led_intensities = dict(getattr(data_mgr, 'leds_calibrated', {}))

            # Debug logging
            logger.debug(f"QC Data - S-pol channels: {list(s_pol_spectra.keys())}")
            logger.debug(f"QC Data - Dark channels: {list(dark_scan.keys())}")
            logger.debug(f"QC Data - Integration time: {integration_time} ms")
            logger.debug(f"QC Data - LED intensities: {led_intensities}")

            qc_data = {
                's_pol_spectra': s_pol_spectra,
                'p_pol_spectra': p_pol_spectra,
                'dark_scan': dark_scan,
                'afterglow_curves': afterglow_curves,
                'transmission_spectra': transmission_spectra,
                'wavelengths': wavelengths,
                'integration_time': integration_time,
                'led_intensities': led_intensities
            }

            logger.info(f"📊 Collected QC data: {len(s_pol_spectra)} S-pol, {len(p_pol_spectra)} P-pol, "
                       f"{len(dark_scan)} dark, {len(afterglow_curves)} afterglow, {len(transmission_spectra)} transmission")

            return qc_data

        except Exception as e:
            logger.error(f"Error collecting QC data: {e}", exc_info=True)
            return {}

    def _close_dialog(self) -> None:
        """Close calibration dialog and clean up."""
        if self._calibration_dialog:
            try:
                self._calibration_dialog.close()
                self._calibration_dialog.deleteLater()
                logger.info("✅ Calibration dialog closed and cleaned up")
            except Exception as e:
                logger.warning(f"Error closing calibration dialog: {e}")
            finally:
                self._calibration_dialog = None

    def _launch_simple_live_window(self) -> None:
        """Launch simple live acquisition window with real hardware."""
        try:
            from core.simple_acquisition import SimpleAcquisitionManager

            logger.info("🚀 Creating simple live window...")

            # Create simple live window
            self._simple_live_window = SimpleLiveWindow(
                self.app.hardware_mgr,
                self.app.data_mgr
            )

            self._simple_live_window.show()
            logger.info("✅ Simple live window launched")

        except Exception as e:
            logger.error(f"❌ Failed to launch simple live window: {e}", exc_info=True)
            import traceback
            traceback.print_exc()


class SimpleLiveWindow(QMainWindow):
    """Simple live data display window using real calibration data."""

    def __init__(self, hardware_mgr, data_mgr):
        super().__init__()
        self.setWindowTitle("Live SPR Data - Simple Acquisition")
        self.resize(1200, 800)

        # Hardware and managers
        self.hardware_mgr = hardware_mgr
        self.data_mgr = data_mgr

        # Create simple acquisition manager
        from core.simple_acquisition import SimpleAcquisitionManager
        self.acq_mgr = SimpleAcquisitionManager(hardware_mgr)

        # Connect signal
        self.acq_mgr.spectrum_ready.connect(self.on_spectrum)

        # Spectrum counter
        self.spectrum_count = {'a': 0, 'b': 0, 'c': 0, 'd': 0}

        # Setup UI
        self.setup_ui()

        # Load calibration data from data_mgr
        self.load_calibration_from_data_mgr()

    def setup_ui(self):
        """Build UI."""
        central = QWidget()
        self.setCentralWidget(central)
        layout = QVBoxLayout(central)

        # Buttons
        btn_layout = QHBoxLayout()

        self.start_btn = QPushButton("Start Acquisition")
        self.start_btn.clicked.connect(self.start_acquisition)
        btn_layout.addWidget(self.start_btn)

        self.stop_btn = QPushButton("Stop Acquisition")
        self.stop_btn.clicked.connect(self.stop_acquisition)
        self.stop_btn.setEnabled(False)
        btn_layout.addWidget(self.stop_btn)

        layout.addLayout(btn_layout)

        # Graphs - 2x2
        graph_container = QWidget()
        graph_layout = QVBoxLayout(graph_container)

        top_row = QHBoxLayout()
        self.plot_a = self.create_plot("Channel A", "#e74c3c")
        self.plot_b = self.create_plot("Channel B", "#3498db")
        top_row.addWidget(self.plot_a['widget'])
        top_row.addWidget(self.plot_b['widget'])
        graph_layout.addLayout(top_row)

        bottom_row = QHBoxLayout()
        self.plot_c = self.create_plot("Channel C", "#2ecc71")
        self.plot_d = self.create_plot("Channel D", "#f39c12")
        bottom_row.addWidget(self.plot_c['widget'])
        bottom_row.addWidget(self.plot_d['widget'])
        graph_layout.addLayout(bottom_row)

        layout.addWidget(graph_container)

        self.plots = {
            'a': self.plot_a,
            'b': self.plot_b,
            'c': self.plot_c,
            'd': self.plot_d
        }

    def create_plot(self, title, color):
        """Create plot widget."""
        widget = pg.PlotWidget()
        widget.setBackground('w')
        widget.setTitle(title, color='k', size='12pt')
        widget.setLabel('left', 'Transmission', units='AU')
        widget.setLabel('bottom', 'Wavelength', units='nm')
        widget.showGrid(x=True, y=True, alpha=0.3)
        widget.setYRange(0, 1.2)

        curve = widget.plot(pen=pg.mkPen(color=color, width=2))

        return {'widget': widget, 'curve': curve}

    def load_calibration_from_data_mgr(self):
        """Load calibration data from the main data manager."""
        try:
            logger.info("📥 Loading calibration data from data_mgr...")

            # Get calibration data from data_mgr
            cal_data = {
                'wavelengths': self.data_mgr.wave_data,
                'dark': self.data_mgr.dark_noise,
                's_ref': self.data_mgr.ref_sig,  # Already a dict with keys 'a', 'b', 'c', 'd'
                'led_intensities': self.data_mgr.leds_calibrated,  # Already a dict
                'integration_time': self.data_mgr.integration_time
            }

            # Set calibration data in simple acquisition manager
            self.acq_mgr.set_calibration_data(cal_data)

            logger.info("✅ Calibration data loaded successfully")
            logger.info(f"   Wavelengths: {len(cal_data['wavelengths'])} points")
            logger.info(f"   Integration time: {cal_data['integration_time']} ms")
            logger.info(f"   LED intensities: {cal_data['led_intensities']}")

        except Exception as e:
            logger.error(f"❌ Failed to load calibration data: {e}", exc_info=True)
            import traceback
            traceback.print_exc()

    def start_acquisition(self):
        """Start acquisition."""
        logger.info("\n🚀 Starting simple acquisition...")
        self.start_btn.setEnabled(False)
        self.stop_btn.setEnabled(True)

        self.acq_mgr.start_acquisition()

    def stop_acquisition(self):
        """Stop acquisition."""
        logger.info("\n⏹️ Stopping simple acquisition...")
        self.start_btn.setEnabled(True)
        self.stop_btn.setEnabled(False)

        self.acq_mgr.stop_acquisition()

        total = sum(self.spectrum_count.values())
        logger.info(f"📊 Total spectra acquired: {total}")

    def on_spectrum(self, data):
        """Handle spectrum data."""
        channel = data['channel']
        wavelength = data['wavelength']
        transmission = data['transmission']

        if transmission is not None:
            # Update graph
            plot = self.plots[channel]
            plot['curve'].setData(wavelength, transmission)

            # Update count
            self.spectrum_count[channel] += 1

            # Update title
            plot['widget'].setTitle(
                f"Channel {channel.upper()} - {self.spectrum_count[channel]} spectra",
                color='k', size='11pt'
            )

    def closeEvent(self, event):
        """Clean shutdown."""
        if self.acq_mgr._acquiring:
            self.stop_acquisition()
        event.accept()
